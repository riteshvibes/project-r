# Flutter / Dart build outputs
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/build/
app/.packages
app/pubspec.lock

# IDE files
.idea/
.vscode/
*.iml
*.ipr
*.iws

# Generated files
app/lib/**/*.g.dart
app/lib/**/*.freezed.dart

# Android
app/android/.gradle/
app/android/captures/
app/android/local.properties
app/android/key.properties
app/android/app/debug/
app/android/app/release/
app/android/app/profile/

# iOS
app/ios/Pods/
app/ios/.symlinks/
app/ios/Flutter/App.framework
app/ios/Flutter/Flutter.framework
app/ios/Flutter/Flutter.podspec
app/ios/Flutter/Generated.xcconfig
app/ios/Flutter/app.flx
app/ios/Flutter/app.zip
app/ios/Flutter/flutter_assets/
app/ios/ServiceDefinitions.json
app/ios/Runner/GeneratedPluginRegistrant.*

# macOS
app/macos/Flutter/GeneratedPluginRegistrant.swift
app/macos/Flutter/ephemeral/

# Web build outputs only (not the Flutter web project sources)
app/build/web/

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
